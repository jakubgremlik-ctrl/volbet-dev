---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'VOLBET.PL', description = 'Twoja platforma do zarabiania' } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="antialiased bg-white text-gray-900">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  body {
    line-height: 1.625;
  }
</style>
