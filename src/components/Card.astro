---
/**
 * Card Component
 * 
 * Displays content in a clean card layout. Variants:
 * - default: General content card with optional image
 * - service: Service card with icon, title, short description, and CTA link
 * 
 * @component
 * @example
 * <Card title="Our Service" description="High-quality solutions">
 *   Content goes here
 * </Card>
 * 
 * <Card 
 *   variant="service"
 *   title="Spoiwa Mineralne"
 *   description="Best-in-class mineral binders"
 *   icon="⚙️"
 *   link="/oferta/spoiwa"
 * />
 */

export interface Props {
  /**
   * Card title
   */
  title?: string;
  
  /**
   * Short description or subtitle
   */
  description?: string;
  
  /**
   * URL to featured image (optional)
   */
  image?: string;
  
  /**
   * Alt text for image
   */
  imageAlt?: string;
  
  /**
   * Optional link/href for service cards
   */
  link?: string;
  
  /**
   * Card variant
   * - default: Standard card with flexible content
   * - service: Service-focused with icon, title, description, and CTA link
   */
  variant?: 'default' | 'service';
  
  /**
   * Icon for service cards (emoji or HTML)
   */
  icon?: string;
  
  /**
   * Link text for service cards
   */
  linkText?: string;
  
  /**
   * Additional CSS classes
   */
  class?: string;
}

const {
  title,
  description,
  image,
  imageAlt = 'Card image',
  link,
  variant = 'default',
  icon,
  linkText = 'Learn more',
  class: additionalClasses = '',
} = Astro.props;

const baseClasses = 'rounded-lg border border-gray-200 overflow-hidden transition-all duration-300 hover:shadow-lg';
const paddingClasses = variant === 'service' ? 'p-6' : 'p-6';
const cardClasses = `${baseClasses} ${paddingClasses} ${additionalClasses}`.trim();

// Design system colors
const navyBlue = '#1A2332';
const mediumGray = '#475569';
const orangeColor = '#D97706';
---

<div class={`card card-${variant} ${cardClasses}`}>
  {/* Service Card Variant */}
  {variant === 'service' && (
    <>
      {icon && (
        <div class="text-5xl mb-4 leading-none">
          {icon}
        </div>
      )}
      
      {title && (
        <h3 class="text-xl font-semibold mb-3" style={`color: ${navyBlue}`}>
          {title}
        </h3>
      )}
      
      {description && (
        <p class="text-base mb-6 leading-relaxed" style={`color: ${mediumGray}`}>
          {description}
        </p>
      )}
      
      {link && (
        <a 
          href={link} 
          class="inline-flex items-center font-semibold transition-colors duration-200 hover:underline"
          style={`color: ${orangeColor}`}
        >
          {linkText}
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </>
  )}
  
  {/* Default Card Variant */}
  {variant === 'default' && (
    <>
      {image && (
        <div class="mb-4 -mx-6 -mt-6 h-48 bg-gray-300 overflow-hidden">
          <img 
            src={image} 
            alt={imageAlt}
            class="w-full h-full object-cover"
          />
        </div>
      )}
      
      {title && (
        <h3 class="text-xl font-semibold mb-3" style={`color: ${navyBlue}`}>
          {title}
        </h3>
      )}
      
      {description && (
        <p class="text-base mb-4 leading-relaxed" style={`color: ${mediumGray}`}>
          {description}
        </p>
      )}
      
      <div class="mt-6">
        <slot />
      </div>
      
      {link && (
        <a 
          href={link}
          class="inline-flex items-center mt-6 font-semibold transition-colors duration-200 hover:underline"
          style={`color: ${orangeColor}`}
        >
          {linkText}
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </>
  )}
</div>

<style>
  .card {
    background-color: #ffffff;
  }
  
  .card-service {
    display: flex;
    flex-direction: column;
  }
  
  .card:hover {
    border-color: #e5e7eb;
  }
</style>
