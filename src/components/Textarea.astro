---
/**
 * Textarea Component
 * 
 * Multi-line text input field with label, validation states, and error messages.
 * Supports auto-growing based on content.
 * 
 * @component
 * @example
 * <Textarea label="Message" name="message" required />
 * <Textarea label="Notes" name="notes" rows={6} />
 * <Textarea label="Description" name="description" error="Field is required" />
 */

export interface Props {
  /**
   * Label text displayed above the textarea
   */
  label?: string;
  
  /**
   * Name attribute for the textarea field
   */
  name: string;
  
  /**
   * Placeholder text
   */
  placeholder?: string;
  
  /**
   * Number of visible text rows
   */
  rows?: number;
  
  /**
   * Whether the field is required
   */
  required?: boolean;
  
  /**
   * Error message to display (shows error state when present)
   */
  error?: string;
  
  /**
   * Helper text displayed below the label
   */
  help?: string;
  
  /**
   * Default value
   */
  value?: string;
  
  /**
   * Disabled state
   */
  disabled?: boolean;
  
  /**
   * Max character length (optional)
   */
  maxLength?: number;
  
  /**
   * Show character counter
   */
  showCounter?: boolean;
  
  /**
   * Additional CSS classes
   */
  class?: string;
}

const {
  label,
  name,
  placeholder = '',
  rows = 5,
  required = false,
  error,
  help,
  value = '',
  disabled = false,
  maxLength,
  showCounter = false,
  class: additionalClasses = '',
} = Astro.props;

// Design system colors
const navyBlue = '#1A2332';
const mediumGray = '#475569';
const orangeColor = '#D97706';
const errorRed = '#DC2626';
const lightGray = '#F8FAFC';
const borderGray = '#E2E8F0';

const hasError = !!error;
const textareaId = `textarea-${name}`;
const charCount = value.length;
const charCountPercent = maxLength ? Math.round((charCount / maxLength) * 100) : 0;
---

<div class={`textarea-wrapper ${additionalClasses}`.trim()}>
  {label && (
    <label 
      for={textareaId}
      class="block text-sm font-semibold mb-2"
      style={`color: ${navyBlue}`}
    >
      {label}
      {required && <span style={`color: ${errorRed}`}>*</span>}
    </label>
  )}
  
  {help && !hasError && (
    <p class="text-xs mb-2" style={`color: ${mediumGray}`}>
      {help}
    </p>
  )}
  
  <textarea
    id={textareaId}
    name={name}
    placeholder={placeholder}
    rows={rows}
    required={required}
    disabled={disabled}
    maxlength={maxLength}
    class={`textarea-field ${hasError ? 'textarea-error' : ''} ${disabled ? 'textarea-disabled' : ''}`}
    style={`
      border-color: ${hasError ? errorRed : borderGray};
      color: ${navyBlue};
    `}
  >
{value}</textarea>
  
  <div class="textarea-footer">
    {error && (
      <p class="text-xs" style={`color: ${errorRed}`}>
        {error}
      </p>
    )}
    
    {showCounter && maxLength && (
      <p class="text-xs" style={`color: ${mediumGray}`}>
        {charCount} / {maxLength}
        {charCountPercent > 80 && charCountPercent <= 100 && (
          <span style={`color: ${orangeColor}`}> (Warning)</span>
        )}
        {charCountPercent > 100 && (
          <span style={`color: ${errorRed}`}> (Exceeded)</span>
        )}
      </p>
    )}
  </div>
</div>

<style define:vars={{
  navyBlue,
  mediumGray,
  orangeColor,
  errorRed,
  lightGray,
  borderGray
}}>
  .textarea-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .textarea-field {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    line-height: 1.5;
    border: 1px solid;
    border-radius: 0.375rem;
    background-color: white;
    font-family: inherit;
    resize: vertical;
    transition: all 0.2s ease-in-out;
  }
  
  .textarea-field:focus {
    outline: none;
    border-color: var(--orangeColor);
    box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.1);
  }
  
  .textarea-field:hover:not(:disabled) {
    border-color: #cbd5e1;
  }
  
  .textarea-field.textarea-error {
    border-color: var(--errorRed);
    background-color: rgba(220, 38, 38, 0.05);
  }
  
  .textarea-field.textarea-error:focus {
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    border-color: var(--errorRed);
  }
  
  .textarea-field.textarea-disabled {
    background-color: var(--lightGray);
    color: #9ca3af;
    cursor: not-allowed;
    opacity: 0.6;
  }
  
  .textarea-field.textarea-disabled:hover {
    border-color: var(--borderGray);
  }
  
  .textarea-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 1.5rem;
  }
  
  label {
    display: block;
  }
</style>
