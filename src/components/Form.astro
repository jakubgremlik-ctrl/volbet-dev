---
/**
 * Form Component
 * 
 * Wrapper for form elements with consistent styling, error handling, and submission states.
 * Handles form state management and validation.
 * 
 * @component
 * @example
 * <Form action="/api/contact" method="POST">
 *   <Input label="Name" name="name" required />
 *   <Input label="Email" name="email" type="email" required />
 *   <Textarea label="Message" name="message" required />
 *   <Button variant="primary" type="submit">Send</Button>
 * </Form>
 */

export interface Props {
  /**
   * Form action URL (where form data is submitted)
   */
  action?: string;
  
  /**
   * HTTP method for form submission
   */
  method?: 'GET' | 'POST';
  
  /**
   * Form title
   */
  title?: string;
  
  /**
   * Form description/subtitle
   */
  description?: string;
  
  /**
   * Show success message after submission
   */
  showSuccess?: boolean;
  
  /**
   * Success message text
   */
  successMessage?: string;
  
  /**
   * Enable form validation feedback
   */
  validateOnBlur?: boolean;
  
  /**
   * Additional CSS classes
   */
  class?: string;
}

const {
  action,
  method = 'POST',
  title,
  description,
  showSuccess = true,
  successMessage = 'Thank you! Your message has been sent successfully.',
  validateOnBlur = true,
  class: additionalClasses = '',
} = Astro.props;

// Design system colors
const navyBlue = '#1A2332';
const mediumGray = '#475569';
const orangeColor = '#D97706';
const successGreen = '#059669';
const errorRed = '#DC2626';

const formClasses = `form-wrapper ${additionalClasses}`.trim();
---

<div class={formClasses}>
  {title && (
    <div class="form-header">
      <h2 class="form-title" style={`color: ${navyBlue}`}>
        {title}
      </h2>
      {description && (
        <p class="form-description" style={`color: ${mediumGray}`}>
          {description}
        </p>
      )}
    </div>
  )}
  
  {showSuccess && (
    <div 
      class="form-success-message"
      style={`
        display: none;
        background-color: rgba(5, 150, 105, 0.1);
        border: 1px solid ${successGreen};
        color: ${successGreen};
        padding: 1rem;
        border-radius: 0.375rem;
        margin-bottom: 1.5rem;
      `}
      data-success-message
    >
      <strong>Success!</strong> {successMessage}
    </div>
  )}
  
  <form 
    class="form-element"
    method={method}
    action={action}
    data-form
  >
    <div class="form-fields">
      <slot />
    </div>
  </form>
</div>

<style define:vars={{
  navyBlue,
  mediumGray,
  orangeColor,
  successGreen,
  errorRed
}}>
  .form-wrapper {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .form-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  
  .form-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    letter-spacing: -0.02em;
  }
  
  .form-description {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    color: var(--mediumGray);
  }
  
  .form-success-message {
    border-radius: 0.375rem;
    margin-bottom: 1.5rem;
    animation: slideDown 0.3s ease-out;
  }
  
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .form-element {
    display: flex;
    flex-direction: column;
  }
  
  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  /* Form field wrapper styling when nested inside form */
  .form-fields :global(> div) {
    display: flex;
    flex-direction: column;
  }
</style>

<script define:vars={{ validateOnBlur }}>
  const form = document.querySelector('[data-form]');
  const successMessage = document.querySelector('[data-success-message]');
  
  if (form) {
    // Handle form submission
    form.addEventListener('submit', async (e) => {
      // Optionally add custom submission logic here
      // For now, default form submission works
    });
    
    // Optional: Blur validation
    if (validateOnBlur) {
      const inputs = form.querySelectorAll('input, textarea');
      inputs.forEach(input => {
        input.addEventListener('blur', () => {
          // Add visual feedback for validation
          if (input.required && !input.value.trim()) {
            input.classList.add('input-invalid');
          } else if (input.type === 'email' && input.value) {
            const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value);
            if (!isValid) {
              input.classList.add('input-invalid');
            } else {
              input.classList.remove('input-invalid');
            }
          } else {
            input.classList.remove('input-invalid');
          }
        });
      });
    }
  }
</script>
